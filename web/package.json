{
  "name": "jci-el-alia-web",
  "type": "module",
  "version": "1.0.0",
  "description": "JCI El Alia — public website (Astro + Sanity)",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
