    "astro": "^6.4.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "wrangler": "^4.96.0"
  }
}
