---
/**
 * All client-side behavior in one place:
 *  - language switching (EN/FR/AR) with RTL + persisted choice
 *  - animated stat counters on scroll into view
 *  - scroll reveal animations
 *  - active nav link highlighting + back-to-top
 *  - polished mobile menu (animated max-height)
 *  - page-load fade-in
 * The full translation dictionary is injected as JSON.
 */
const {translations} = Astro.props
---

<script is:inline define:vars={{translations}}>
  (function () {
    const rtlLangs = ['ar']

    // ---- Language switching ----
    function setLang(lang) {
      const html = document.documentElement
      const isRtl = rtlLangs.includes(lang)
      html.setAttribute('lang', lang)
      html.setAttribute('dir', isRtl ? 'rtl' : 'ltr')
      document.body.style.fontFamily = isRtl
        ? '"Noto Sans Arabic", sans-serif'
        : '"Plus Jakarta Sans", sans-serif'

      const dict = translations[lang] || translations.en
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n')
        if (dict[key] != null) el.textContent = dict[key]
      })
      document.querySelectorAll('[data-i18n-ph]').forEach((el) => {
        const key = el.getAttribute('data-i18n-ph')
        if (dict[key] != null) el.setAttribute('placeholder', dict[key])
      })
      document.querySelectorAll('.lang-btn').forEach((btn) => {
        const active = btn.getAttribute('data-lang') === lang
        btn.classList.toggle('active', active)
        btn.classList.toggle('text-jci-black/60', !active)
      })
      try { localStorage.setItem('jci-lang', lang) } catch (e) {}
    }

    document.querySelectorAll('.lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => setLang(btn.getAttribute('data-lang')))
    })

    // Restore saved language
    let saved = 'en'
    try { saved = localStorage.getItem('jci-lang') || 'en' } catch (e) {}
    if (saved !== 'en') setLang(saved)

    // ---- Mobile menu (animated) ----
    const menuBtn = document.getElementById('mobile-menu-btn')
    const mobileMenu = document.getElementById('mobile-menu')
    function closeMenu() {
      mobileMenu.style.maxHeight = '0px'
      const icon = menuBtn.querySelector('i')
      icon.classList.add('fa-bars'); icon.classList.remove('fa-times')
    }
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const open = mobileMenu.style.maxHeight && mobileMenu.style.maxHeight !== '0px'
        const icon = menuBtn.querySelector('i')
        if (open) { closeMenu() }
        else {
          mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px'
          icon.classList.remove('fa-bars'); icon.classList.add('fa-times')
        }
      })
      mobileMenu.querySelectorAll('a[href^="#"]').forEach((l) => l.addEventListener('click', closeMenu))
    }

    // ---- Scroll reveal ----
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target) } })
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' })
    document.querySelectorAll('.reveal').forEach((el) => revealObs.observe(el))

    // ---- Counters ----
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    function animateCounter(el) {
      const target = parseInt(el.getAttribute('data-target'), 10) || 0
      if (reduceMotion) { el.textContent = target.toString(); return }
      const dur = 1600, start = performance.now()
      function step(now) {
        const p = Math.min((now - start) / dur, 1)
        const eased = 1 - Math.pow(1 - p, 3)
        el.textContent = Math.round(eased * target).toString()
        if (p < 1) requestAnimationFrame(step)
      }
      requestAnimationFrame(step)
    }
    const counterObs = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { animateCounter(e.target); counterObs.unobserve(e.target) } })
    }, { threshold: 0.5 })
    document.querySelectorAll('.counter').forEach((el) => counterObs.observe(el))

    // ---- Active nav + back to top ----
    const sects = document.querySelectorAll('section[id]')
    const navLks = document.querySelectorAll('.nav-link')
    const backTop = document.getElementById('back-to-top')
    if (backTop) backTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))
    window.addEventListener('scroll', () => {
      let cur = ''
      sects.forEach((s) => { if (window.scrollY >= s.offsetTop - 100) cur = s.id })
      navLks.forEach((l) => l.classList.toggle('active', l.getAttribute('href') === '#' + cur))
      if (backTop) backTop.classList.toggle('visible', window.scrollY > 600)
    })

    // ---- Page load fade-in ----
    document.body.classList.add('page-loaded')
  })()
</script>
