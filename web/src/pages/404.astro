---
/**
 * 404 page — on-brand, with a route back home. Cloudflare Pages serves this
 * automatically for unknown paths.
 */
import Base from '../layouts/Base.astro'
---

<Base title="Page not found | JCI El Alia">
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-br from-jci-black via-jci-navy to-jci-blue px-6">
    <div class="text-center">
      <p class="text-jci-teal font-semibold uppercase tracking-widest mb-4">404</p>
      <h1 class="text-4xl sm:text-5xl font-light text-white mb-4">Page not found</h1>
      <p class="text-white/60 max-w-md mx-auto mb-8">
        The page you’re looking for doesn’t exist or may have moved.
      </p>
      <a href="/" class="inline-block bg-jci-blue hover:bg-white hover:text-jci-blue text-white px-8 py-4 rounded-full font-semibold transition-all duration-300 shadow-lg shadow-jci-blue/30">
        Back to home
      </a>
    </div>
  </main>
</Base>
